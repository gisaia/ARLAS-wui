{
  "name": "arlas-wui",
  "workspaces": [
    "packages/cloud",
    "packages/opensource"
  ],
  "version": "27.2.0-dev",
  "author": "gisaia",
  "repository": {
    "type": "git",
    "url": "https://github.com/gisaia/ARLAS-wui.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "ng": "ng",
    "serve-cloud": "ng serve --configuration=development-cloud",
    "postinstall": "patch-package --patch-dir node_modules/arlas-web-core/patches && patch-package --patch-dir node_modules/arlas-d3/patches",
    "start": "ng serve --configuration=development-opensource",
    "start:iam": "ng serve --ssl --ssl-cert=$EXPLO_SSL_CERT --ssl-key=$EXPLO_SSL_KEY  --configuration=development-opensource",
    "build-opensource-stats": "ng build arlas-wui --configuration production-opensource --aot --base-href='$ARLAS_WUI_BASE_HREF/' --stats-json --metafile=meta.json",
    "build-opensource": "ng build arlas-wui --configuration production-opensource --aot --base-href='$ARLAS_WUI_BASE_HREF/'",
    "build-lib": "ng build arlas-wui-lib --configuration production",
    "analyze-opensource": "esbuild-visualizer --metadata dist/stats.json",
    "build-cloud": "ng build arlas-wui --configuration production-cloud --aot --base-href='$ARLAS_WUI_BASE_HREF/'",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "i18n:init": "ngx-translate-extract --input ./src --output ./src/assets/i18n/template.json --key-as-default-value --replace --format json",
    "i18n:extract": "ngx-translate-extract --input ./src --output ./src/assets/i18n/{en,fr,es}.json --format json",
    "license-check": "license-check-and-add check -f license-check-and-add.json"
  },
  "peerDependencies": {
    "@angular/animations": "^20.3.15",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.15",
    "@angular/compiler": "^20.3.15",
    "@angular/core": "^20.3.15",
    "@angular/forms": "^20.3.15",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.15",
    "@angular/platform-browser-dynamic": "^20.3.15",
    "@angular/router": "^20.3.15",
    "rxjs": "^7.4.0",
    "zone.js": "^0.15.1"
  },
  "dependencies": {
    "@ngx-translate/core": "^17.0.0",
    "arlas-wui-toolkit": "28.0.0-beta.2",
    "hammerjs": "^2.0.8",
    "ng-packagr": "^20.3.2",
    "ngx-markdown": "^20.0.0",
    "patch-package": "^6.4.7",
    "web-animations-js": "^2.3.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.14",
    "@angular-eslint/builder": "~20.7.0",
    "@angular-eslint/eslint-plugin": "~20.7.0",
    "@angular-eslint/eslint-plugin-template": "~20.7.0",
    "@angular-eslint/schematics": "~20.7.0",
    "@angular-eslint/template-parser": "~20.7.0",
    "@angular/cli": "^20.3.14",
    "@angular/compiler-cli": "^20.3.16",
    "@angular/language-service": "^20.3.16",
    "@colsen1991/ngx-translate-extract-marker": "^3.0.1",
    "@types/jasmine": "~3.10.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vendure/ngx-translate-extract": "^9.3.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.39.1",
    "jasmine": "^5.1.0",
    "jasmine-core": "~3.10.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "license-check-and-add": "^4.0.5",
    "node": "^24.10.1",
    "ts-node": "~10.4.0",
    "typescript": "5.9.3",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
